# Copy to .env for `docker compose` and local `npm run dev`.
# Only the API key is required; the rest have sensible defaults.
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://opencode.ai/zen/v1
AI_MODEL=north-mini-code-free

# ---- MongoDB (all app data) ----
MONGODB_URI=mongodb://localhost:27017/shmora

# ---- Firebase Admin (auth verification only) ----
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
