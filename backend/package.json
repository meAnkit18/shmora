{
  "name": "infinite-teacher-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --clean --outDir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "try:ai": "tsx scripts/tryAi.ts",
    "try:flow": "tsx scripts/tryFlow.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "socket.io-client": "^4.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
