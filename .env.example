PORT=3001
AI_BASE_URL=https://opencode.ai/zen/v1
AI_API_KEY=your-api-key-here
AI_MODEL=north-mini-code-free
CLIENT_ORIGIN=http://localhost:5173

# ---- MongoDB (all app data) ----
MONGODB_URI=mongodb://localhost:27017/shmora

# ---- Firebase Admin (auth verification only) ----
# From Firebase console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep the quotes and the \n characters exactly as they appear in the JSON file:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
